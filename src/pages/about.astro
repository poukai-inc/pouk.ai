---
/**
 * /about — v2. Orange band + portrait + brand-voice body.
 *
 * Supersedes v1 (composition verdict (ii) — no <Hero>, first-person prose).
 * v2 re-adopts <Hero> for the opening band per composition v2 Approved verdict.
 *
 * Composition recipe: meta/compositions/pages/about.md v2 (Approved 2026-05-18).
 * PM spec: meta/specs/pages/about.md v2 (Approved 2026-05-18).
 * Content: meta/content/drafts/pages/about.md v2.0 (Approved 2026-05-18).
 *
 * Page structure (5 units, composition §2):
 *   Unit 1 — <SiteShell> header chrome (via BaseLayout + ShellWrapper)
 *   Unit 2 — <AboutBand> — full-bleed orange Hero band (display statement +
 *             portrait). The page's <h1> lives inside <Hero>'s title slot.
 *   Unit 3 — Story body (2 paragraphs, ~91 words, brand-voice declarative)
 *             + operator line (names Arian once, third-person)
 *   Unit 4 — Pouākai section (<h2> + 3-sentence verbatim body, 75 words)
 *   Unit 5 — End CTA (muted line, mailto link) + <SiteShell> footer chrome
 *
 * Decisions honoured:
 *   A4  — four-item nav: Why AI → Roles → Principles → About
 *   A9  — <h1> is the display statement (moves from section 1 in v1 to the
 *          Hero title slot in v2)
 *   A11 — /principles-style brand-voice end-CTA; differentiated wording
 *   A14 — <title> "About — pouk.ai" (em-dash); meta description brand-voice
 *   A15 — standalone Person JSON-LD; no worksFor; no sameAs
 *   v2 reversals: A5 retired (no first-person), A6 retired (≤250 words),
 *                 A10 retired (no autobiographical framing)
 *
 * Quality contracts:
 *   - Zero client:* directives. Motion = <Hero entrance="stagger"> CSS only.
 *   - Exactly one <h1> (display statement via Hero title slot).
 *   - Exactly one <h2> (Pouākai section heading).
 *   - No first-person "I" anywhere on the rendered page.
 *   - Operator name (Arian Zargaran) appears exactly once — in the operator line.
 *   - R27 sentence verbatim: "Named for Pouākai — the largest eagle..."
 *   - axe-clean: substantive portrait alt, landmark structure, heading hierarchy.
 *   - Lighthouse 100/100/100/100 mobile.
 */

import BaseLayout from "../layouts/BaseLayout.astro";
import { AboutBand } from "../components/AboutBand";

const pageTitle = "About — pouk.ai";

/**
 * Meta description — brand-voice, 133 chars (under 155 cap).
 * Rewrites v1's founder-arc framing per spec §6.2 + A14 revision.
 * Copy: meta/content/drafts/pages/about.md §2 pageDescription (v2.0).
 */
const pageDescription =
  "pouk.ai is a small technical consultancy that builds and ships AI work in production. One operator. Direct contact at hello@pouk.ai.";

const canonical = "https://pouk.ai/about";

/**
 * Standalone Person JSON-LD — spec §6.2 / A15 (holds from v1).
 * Fields: name, jobTitle, url only. No worksFor. No sameAs.
 * No fields surfacing the portrait or its AI provenance.
 * jobTitle revised from v1's "Founder, pouk.ai" to "Founder" (cleaner schema).
 */
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Arian Zargaran",
  jobTitle: "Founder",
  url: "https://pouk.ai/about",
};

/**
 * Portrait asset path — Astro serves public/ assets at root.
 * Source: public/about-portrait.jpg (1024×1024, 78KB JPEG).
 * DS <Portrait> molecule generates AVIF/WebP/JPEG srcset at build time
 * from this URL path.
 */
const portraitSrc = "/about-portrait.jpg";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonical}
  jsonLd={jsonLd}
  currentRoute="/about"
  portraitPreload={portraitSrc}
>
  <!--
    Unit 2 — Portrait band.
    AboutBand.tsx wraps <Hero bleed="full" illustration={<Portrait>} entrance="stagger">.
    The band breaks out of .site-page's max-width via <Hero bleed="full">.
    Orange surface: var(--bg-warm-accent) applied on .about-band wrapper (site.css).
    The page's single <h1> lives inside Hero's title slot.
    No client:* directive — static render, CSS-only entrance animation.
  -->
  <!--
    AboutBand renders as static HTML at build time — no hydration directive.
    Zero client JS. Astro statically renders the React component tree via
    @astrojs/react's server renderer. Motion is CSS-only (entrance="stagger").
  -->
  <AboutBand portraitSrc={portraitSrc} />

  <!--
    Units 3–5 — Story body, Pouākai section, end CTA.
    Returns to .site-page container (max-width: var(--content-max)) after the band.
    No DS primitives needed here — plain semantic HTML with DS token classes.
  -->
  <div class="site-page about-tail">

    <!--
      Unit 3 — Story body.
      2 paragraphs, ~91 words total, brand-voice declarative throughout.
      No <h2> heading above (composition §2 Unit 3 — "the display statement
      is the only display moment; adding a heading here would compete").
      No inline mailto link (composition §2 Unit 3 — "CTA lives at end only").
      Copy: meta/content/drafts/pages/about.md §2 storyBody + operatorLine.
    -->
    <section class="about-story" aria-label="About pouk.ai">
      <div class="about-story__body">
        <p>
          pouk.ai builds custom AI systems, automations, and advisory
          engagements for teams that need the work to run in production,
          not in a report. Modern AI tools collapse what used to take a
          dev team six months into days, sometimes weeks for the harder
          parts. A small consultancy that has wired these tools into
          production codebases can do it again on a new team&rsquo;s
          stack &mdash; quickly, without a strategy retreat first.
        </p>
        <p>
          Engagements are small and direct. pouk.ai works one team at a
          time. The output is a system the in-house team can run, not a
          deck that needs translation.
        </p>
        <!--
          Operator line — names Arian once, third-person, brand-voice.
          This is the ONLY surface where the operator's name appears on
          the page body. Per spec §8 AC and content draft v2.0 §2.
          Copy: meta/content/drafts/pages/about.md §2 operatorLine (Q4 ratified).
          Verb-first construction reads as continuation of the story body.
        -->
        <p class="about-story__operator">
          Founded and run by Arian Zargaran. Direct contact at{" "}
          <a href="mailto:hello@pouk.ai">hello@pouk.ai</a>.
        </p>
      </div>
    </section>

    <!--
      Unit 4 — Pouākai section.
      <h2> heading — only heading rank below the display statement <h1>.
      Instrument Serif italic at --fs-tagline-intimate per composition §2 Unit 4.
      Body: 3 sentences, 75 words, verbatim from v1 (R27 verbatim + 2 sentences).
      Macron: literal Unicode U+0101 (ā) — canonical per existing v1 pattern.
      Anchor: id="poukai" per content draft §2.
      Copy: meta/content/drafts/pages/about.md §2 poukaiUnit (Q5 ratified —
            verbatim carry-forward; no compression).
    -->
    <section class="about-poukai" aria-labelledby="poukai">
      <h2 id="poukai" class="about-poukai__heading">Pou&#257;kai</h2>
      <p class="about-poukai__body">
        Named for Pou&#257;kai &mdash; the largest eagle that ever flew,
        hunting by stooping from height. The name comes from M&#257;ori
        tradition; the bird is real, extinct for around six hundred
        years, and the spelling carries the macron it was given.
        pouk.ai borrows the name as a reference point &mdash; a hunter
        that worked by altitude and timing &mdash; and stops there: no
        M&#257;ori visual motifs in the brand, no claim to the culture,
        no metaphor stretched past the one-line origin.
      </p>
    </section>

    <!--
      Unit 5 — End CTA.
      Single muted line with mailto link. Brand-voice / second-person invitational.
      Hairline above for rhythm parity with /principles end-CTA pattern.
      Differentiated from sibling CTAs per composition §2 Unit 5 + content draft §2.
      Copy: meta/content/drafts/pages/about.md §2 endCta.
      "For inbound work" names the purpose; display statement + story body have
      done the qualifying work so the CTA just points.
    -->
    <div class="end-cta">
      <p>
        For inbound work,{" "}
        <a href="mailto:hello@pouk.ai">hello@pouk.ai</a>.
      </p>
    </div>

  </div>
</BaseLayout>
